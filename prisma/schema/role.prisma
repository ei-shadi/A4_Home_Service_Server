model Role {
  // Primary Key
  id String @id @default(uuid()) @db.Uuid

  // Business Fields
  name        String  @unique @db.VarChar(50)
  description String? @db.Text

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users User[]

  @@map("roles")
}
